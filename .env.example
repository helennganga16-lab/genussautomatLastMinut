# Kopiere diese Datei zu .env und trage deine Werte ein.
# .env wird NICHT committed (siehe .gitignore).
# Auf Produktionssystemen (Vercel, Hosting) bitte Server-Env-Vars direkt setzen —
# .env ist nur für die lokale Entwicklung gedacht.

# E-Mail-Empfänger für Kontaktanfragen
CONTACT_RECEIVER_EMAIL=office@genussautomaten.at

# Absender-Adresse und -Name
MAIL_FROM=noreply@genussautomaten.at
MAIL_FROM_NAME=Genussautomaten Kontaktformular

# SMTP (nur wenn dein Hoster SMTP statt PHP mail() erfordert)
# Diese Werte werden erst aktiv, wenn sendContactMail() auf SMTP umgestellt wird.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=dein-passwort
